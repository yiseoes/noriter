<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
        <Property name="LOG_DIR">./logs</Property>
    </Properties>

    <Appenders>
        <!-- 콘솔 출력 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout charset="UTF-8" pattern="%d{HH:mm:ss.SSS} %-5level [%t] %logger{36} - %msg%n"/>
        </Console>

        <!-- 파일 출력 (일별 롤링) -->
        <RollingFile name="File"
                     fileName="${LOG_DIR}/noriter.log"
                     filePattern="${LOG_DIR}/noriter-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <!-- 에이전트 전용 로그 -->
        <RollingFile name="AgentFile"
                     fileName="${LOG_DIR}/agent.log"
                     filePattern="${LOG_DIR}/agent-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <!-- 파이프라인 전용 로그 -->
        <RollingFile name="PipelineFile"
                     fileName="${LOG_DIR}/pipeline.log"
                     filePattern="${LOG_DIR}/pipeline-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- 놀이터 에이전트 로거 -->
        <Logger name="com.noriter.agent" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AgentFile"/>
        </Logger>

        <!-- 놀이터 파이프라인 로거 -->
        <Logger name="com.noriter.agent.pipeline" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="PipelineFile"/>
        </Logger>

        <!-- 놀이터 전체 -->
        <Logger name="com.noriter" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Spring / Hibernate -->
        <Logger name="org.springframework" level="INFO"/>
        <Logger name="org.hibernate.SQL" level="DEBUG"/>
        <Logger name="org.hibernate.type.descriptor.sql" level="TRACE"/>

        <!-- Root -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>

</Configuration>
